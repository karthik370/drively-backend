# Server Configuration
NODE_ENV=development
PORT=5000
API_VERSION=v1

# Database
DATABASE_URL="postgresql://postgres:6095@localhost:5432/drivemate?schema=public"

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_REFRESH_SECRET=your-refresh-secret-key
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# Encryption
ENCRYPTION_KEY=your-32-character-encryption-key

# Twilio (SMS)
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1234567890

# MSG91 (OTP)
MSG91_AUTHKEY=your-msg91-authkey

# SendGrid (Email)
SENDGRID_API_KEY=your-sendgrid-api-key
SENDGRID_FROM_EMAIL=noreply@drivemate.com
SENDGRID_FROM_NAME=DriveMate

# Firebase (Push Notifications)
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_PRIVATE_KEY=your-firebase-private-key
FIREBASE_CLIENT_EMAIL=your-firebase-client-email

# Google Maps
GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# Railway Native Object Storage (Buckets)
RAILWAY_BUCKET_NAME=my-project-bucket
RAILWAY_BUCKET_REGION=us-west-1
RAILWAY_BUCKET_ENDPOINT=https://s3.us-west-1.railway.app
RAILWAY_BUCKET_ACCESS_KEY_ID=your-railway-access-key
RAILWAY_BUCKET_SECRET_ACCESS_KEY=your-railway-secret-key
RAILWAY_BUCKET_PUBLIC_URL=https://my-bucket.up.railway.app

# Cloudinary (Alternative to S3)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Razorpay
RAZORPAY_KEY_ID=your-razorpay-key-id
RAZORPAY_KEY_SECRET=your-razorpay-key-secret

# Stripe
STRIPE_SECRET_KEY=your-stripe-secret-key
STRIPE_PUBLISHABLE_KEY=your-stripe-publishable-key
STRIPE_WEBHOOK_SECRET=your-stripe-webhook-secret

# Sentry
SENTRY_DSN=your-sentry-dsn

# Commission & Pricing
PLATFORM_COMMISSION_PERCENTAGE=12
BASE_FARE=50
PER_KM_RATE=10
PER_MINUTE_RATE=2
CANCELLATION_CHARGE=30
SURGE_MULTIPLIER=1.5

# App URLs
MOBILE_APP_URL=exp://192.168.1.100:19000
ADMIN_DASHBOARD_URL=http://localhost:3000
FRONTEND_URL=http://localhost:3000

# DigiLocker (Aadhaar Verification - India)
DIGILOCKER_CLIENT_ID=your-digilocker-client-id
DIGILOCKER_CLIENT_SECRET=your-digilocker-client-secret

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
